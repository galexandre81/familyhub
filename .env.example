# Hub React (Vite — préfixées VITE_)
# Récupère les valeurs dans Firebase Console → Project settings → General → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=family-hub-guillaume.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=family-hub-guillaume
VITE_FIREBASE_STORAGE_BUCKET=family-hub-guillaume.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URLs
VITE_HUB_URL=https://family-hub-guillaume.web.app
VITE_DISPLAY_URL=https://family-hub-guillaume.web.app/display

# Phase 2+
VITE_GOOGLE_CALENDAR_CLIENT_ID=

# Cloud Functions secrets (set via `firebase functions:secrets:set NAME`)
# OPEN_METEO_BASE=https://api.open-meteo.com/v1
