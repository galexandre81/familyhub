rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // setupShortIds : lookup table accédée uniquement via Admin SDK (Cloud Functions).
    // Les clients web/display passent par les Functions (resolveSetupShortId) qui bypassent ces rules.
    match /setupShortIds/{shortId} {
      allow read, write: if false;
    }

    // Users : chacun lit/écrit son propre doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Helpers : un display authentifié via custom token a le claim isDisplay=true et son householdId.
    function isMember(hid) {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.membres;
    }
    function isDisplayOfHousehold(hid) {
      return request.auth != null
        && request.auth.token.isDisplay == true
        && request.auth.token.householdId == hid;
    }

    // Households : membres lisent/écrivent. Displays peuvent lire et changer
    // uniquement parametres.themeId (tuile Réglages iPad) — toute autre
    // modification depuis un display est refusée.
    match /households/{hid} {
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.membres
                      || isDisplayOfHousehold(hid));
      allow update: if request.auth != null
                    && (
                      (
                        request.auth.uid in resource.data.membres
                        && request.resource.data.ownerUid == resource.data.ownerUid
                        && request.resource.data.membres == resource.data.membres
                      ) ||
                      (
                        isDisplayOfHousehold(hid)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parametres', 'updatedAt'])
                        && request.resource.data.parametres.diff(resource.data.parametres).affectedKeys().hasOnly(['themeId'])
                      )
                    );
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;

      // Timers : displays peuvent aussi écrire (création/pause/stop depuis l'iPad cuisine).
      match /timers/{timerId} {
        allow read, write: if isMember(hid) || isDisplayOfHousehold(hid);
      }

      // Recettes : membres = read/write. Les displays (tuile recette du jour)
      // votent en écrivant statut/excluded/updatedAt sur le doc recette.
      // Firestore autorise dès qu'UNE règle correspondante l'autorise : ce
      // bloc spécifique s'ajoute au catch-all foyer-scope ci-dessous.
      match /recettes/{recetteId} {
        allow read: if isMember(hid) || isDisplayOfHousehold(hid);
        allow write: if isMember(hid);
        allow update: if isMember(hid)
                      || (
                        isDisplayOfHousehold(hid)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['statut', 'excluded', 'updatedAt'])
                      );
      }

      // Sous-collections : membres = read/write, displays = read seul.
      //
      // Phase 3 (meal planner / recettes / liste de courses) :
      // profils, mealPlans, mealPlans/{id}/slots, recettes,
      // shoppingLists, coursesItems — toutes couvertes par cette règle
      // générique foyer-scope. L'enforcement de checkedAt/checkedBy au
      // cochage d'un item de courses est porté côté client (l'array
      // `items` est dans le doc parent, non validable par élément côté
      // rules).
      match /{collection}/{docId=**} {
        allow read: if isMember(hid) || isDisplayOfHousehold(hid);
        allow write: if isMember(hid);
      }
    }
  }
}
