# Copie ce fichier en .env et complète.

# ID du projet Firebase. Obligatoire si tu utilises Application Default Credentials
# (gcloud auth application-default login).
FIREBASE_PROJECT_ID=family-hub-guillaume

# Chemin vers le service-account JSON Firebase.
# À télécharger sur https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk
# Si non défini, le script tentera Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Provider LLM par défaut : "gemini" (cloud, payant) ou "lmstudio" (local, gratuit).
# Peut être overridé en ligne de commande avec --provider.
LLM_PROVIDER=gemini

# Clé API Google AI Studio pour Gemini. Obligatoire si LLM_PROVIDER=gemini.
# À récupérer sur https://aistudio.google.com/apikey
GEMINI_API_KEY=
